#!/bin/bash

_tis_web_completions() {
    local cur prev base_dir actions envs sites github_repos
    local current_dir="$PWD"
    local action="${COMP_WORDS[1]}"

    base_dir="/home/tis/websites"
    actions="create-env install pull status down up edit remove help"
    
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Helper function to remove items from suggestions based on an exclude list
    _filter_list() {
        local all_items="$1"
        local exclude_items=" $(echo $2) "
        local filtered=""
        
        for item in $all_items; do
            if [[ ! "$exclude_items" == *" $item "* ]]; then
                filtered="$filtered $item"
            fi
        done
        echo "$filtered"
    }

    # --- 1. Actions (Level 1) ---
    if [ $COMP_CWORD -eq 1 ]; then
        COMPREPLY=( $(compgen -W "$actions" -- "$cur") )
        return 0
    fi

    # --- 2. Action Filtering ---
    if [[ "$action" == "create-env" || "$action" == "help" ]]; then
        COMPREPLY=()
        return 0
    fi

    # --- 3. Context Logic ---
    local context="anywhere"
    local detected_env=""
    
    if [[ "$current_dir" == "$base_dir" ]]; then
        context="root"
    elif [[ "$current_dir" == "$base_dir"/*/* ]]; then 
        context="site"
    elif [[ "$current_dir" == "$base_dir"/* ]]; then 
        context="env"
        detected_env=$(basename "$current_dir")
    fi

    # --- 4. Suggestions based on Position & Context ---
    
    # CASE A: We are inside a SITE folder
    if [[ "$context" == "site" ]]; then
        COMPREPLY=()
        return 0
    fi

    # CASE B: We are inside an ENV folder (Pos 2 onwards are SITES)
    if [[ "$context" == "env" ]]; then
        # LOCK: Block further suggestions if action is single-target and a site is already provided
        if [[ "$action" =~ ^(install|edit|remove)$ ]] && [ $COMP_CWORD -gt 2 ]; then
            COMPREPLY=()
            return 0
        fi

        if [[ "$action" == "install" ]]; then
            if [ -f "/home/tis/.github_token" ]; then
                github_repos=$(curl -s -H "Authorization: Bearer $(cat /home/tis/.github_token)" "https://api.github.com/orgs/TechITSimple/repos?per_page=100" | grep -o '"name": "[^"]*' | cut -d'"' -f4 | tr -d '\r')
            else
                github_repos=$(curl -s "https://api.github.com/orgs/TechITSimple/repos?per_page=100" | grep -o '"name": "[^"]*' | cut -d'"' -f4 | tr -d '\r')
            fi
            
            local existing_sites=$(cd "$current_dir" 2>/dev/null && compgen -d)
            local excludes="${COMP_WORDS[@]} tis-web $existing_sites"
            
            sites=$(_filter_list "$github_repos" "$excludes")
            COMPREPLY=( $(compgen -W "$sites" -- "$cur") )
        else
            sites=$(cd "$current_dir" 2>/dev/null && compgen -d)
            local excludes="${COMP_WORDS[@]}"
            sites=$(_filter_list "$sites" "$excludes")
            
            if [[ $COMP_CWORD -eq 2 && "$action" =~ ^(pull|status|down|up)$ ]]; then
                sites="-a $sites"
            fi
            COMPREPLY=( $(compgen -W "$sites" -- "$cur") )
        fi
        return 0
    fi

    # CASE C: We are at ROOT / Anywhere Else
    if [[ "$context" == "root" || "$context" == "anywhere" ]]; then
        # Pos 2 is ALWAYS the Environment
        if [ $COMP_CWORD -eq 2 ]; then
            if [ -d "$base_dir" ]; then
                envs=$(cd "$base_dir" 2>/dev/null && compgen -d)
                COMPREPLY=( $(compgen -W "$envs" -- "$cur") )
            fi
            return 0
        fi

        # Pos 3 onwards are SITES
        if [ $COMP_CWORD -ge 3 ]; then
            # LOCK: Block further suggestions if action is single-target and a site is already provided
            if [[ "$action" =~ ^(install|edit|remove)$ ]] && [ $COMP_CWORD -gt 3 ]; then
                COMPREPLY=()
                return 0
            fi

            local sel_env="${COMP_WORDS[2]}"
            if [ -d "$base_dir/$sel_env" ]; then
                if [[ "$action" == "install" ]]; then
                    if [ -f "/home/tis/.github_token" ]; then
                        github_repos=$(curl -s -H "Authorization: Bearer $(cat /home/tis/.github_token)" "https://api.github.com/orgs/TechITSimple/repos?per_page=100" | grep -o '"name": "[^"]*' | cut -d'"' -f4 | tr -d '\r')
                    else
                        github_repos=$(curl -s "https://api.github.com/orgs/TechITSimple/repos?per_page=100" | grep -o '"name": "[^"]*' | cut -d'"' -f4 | tr -d '\r')
                    fi
                    
                    local existing_sites=$(cd "$base_dir/$sel_env" 2>/dev/null && compgen -d)
                    local excludes="${COMP_WORDS[@]} tis-web $existing_sites"
                    
                    sites=$(_filter_list "$github_repos" "$excludes")
                    COMPREPLY=( $(compgen -W "$sites" -- "$cur") )
                else
                    sites=$(cd "$base_dir/$sel_env" 2>/dev/null && compgen -d)
                    local excludes="${COMP_WORDS[@]}"
                    sites=$(_filter_list "$sites" "$excludes")
                    
                    if [[ $COMP_CWORD -eq 3 && "$action" =~ ^(pull|status|down|up)$ ]]; then
                        sites="-a $sites"
                    fi
                    COMPREPLY=( $(compgen -W "$sites" -- "$cur") )
                fi
            fi
        fi
    fi
}

complete -F _tis_web_completions tis-web
